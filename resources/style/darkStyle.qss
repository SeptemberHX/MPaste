/*
 * input: Depends on Qt style system and resource paths.
 * output: Provides dark theme color overrides for the main window and common controls.
 * pos: resources/style theme stylesheet.
 * update: Keep this header and resources/style/README.md in sync.
 * note: Added for dark theme support.
 */
QWidget#pasteWidget {
    background-color: transparent;  /* Background and gradient border are painted in paintEvent */
}

QWidget#pasteWidget,
QWidget#pasteWidget QLabel,
QWidget#pasteWidget QToolButton,
QWidget#pasteWidget QPushButton {
    color: {{text_primary}};
}

QToolButton#clipboardButton,
QToolButton#staredButton,
QToolButton#allTypeBtn,
QToolButton#textTypeBtn,
QToolButton#linkTypeBtn,
QToolButton#imageTypeBtn,
QToolButton#richTextTypeBtn,
QToolButton#fileTypeBtn {
    color: {{tab_text}};
}

#firstButton:hover, #lastButton:hover,
#firstButton:selected, #lastButton:selected,
#searchButton:selected, #searchButton:hover,
#menuButton:selected, #menuButton:hover {
    background-color: {{top_hover_bg}};
}

/* Input box — glass style */
QLineEdit {
    border: 1.5px solid rgba(255, 255, 255, 18);
    background-color: rgba(255, 255, 255, 10);
    color: {{text_primary}};
}

QLineEdit:focus {
    border-color: rgba(74, 144, 226, 140);
}

/* Count badge — glass pill */
QToolButton#countArea {
    background-color: rgba(255, 255, 255, 14);
    color: {{badge_text}};
    border: 1px solid rgba(255, 255, 255, 22);
}

QToolButton#countArea:hover {
    background-color: rgba(255, 255, 255, 28);
    border-color: rgba(255, 255, 255, 35);
}

/* Clipboard tabs — glass style for dark mode */
QWidget#clipboardBtnWidget QToolButton {
    background-color: transparent;
    border: none;
}
QWidget#clipboardBtnWidget QToolButton#clipboardButton:hover,
QWidget#clipboardBtnWidget QToolButton#clipboardButton:pressed,
QWidget#clipboardBtnWidget QToolButton#clipboardButton:checked,
QWidget#clipboardBtnWidget QToolButton#clipboardButton:focus {
    background-color: rgba(255, 255, 255, 28);
    border: 1px solid rgba(255, 255, 255, 36);
    color: {{tab_text}};
}
QWidget#clipboardBtnWidget QToolButton#staredButton:hover,
QWidget#clipboardBtnWidget QToolButton#staredButton:pressed,
QWidget#clipboardBtnWidget QToolButton#staredButton:checked,
QWidget#clipboardBtnWidget QToolButton#staredButton:focus {
    background-color: rgba(255, 255, 255, 28);
    border: 1px solid rgba(255, 255, 255, 36);
    color: {{tab_text}};
}

/* Type filter pills — glass style for dark mode */
QWidget#typeBtnWidget QToolButton:hover,
QWidget#typeBtnWidget QToolButton:pressed,
QWidget#typeBtnWidget QToolButton:checked {
    background-color: rgba(255, 255, 255, 24);
    border: 1px solid rgba(255, 255, 255, 32);
    color: {{tab_text}};
}

/* About window */
QWidget#AboutWidget {
    background-color: {{menu_bg}};
    border: 1px solid {{menu_border}};
}
QWidget#AboutWidget QLabel {
    color: {{text_primary}};
}
